# ============================================================
# Context-Aware RAG Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- API Keys ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-gemini-api-key-here

# --- LLM Settings ---
LLM_PROVIDER=gemini           # gemini | openai | ollama
LLM_MODEL=gemini-2.0-flash    # gemini-2.0-flash | gemini-1.5-pro | gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# --- Embedding Settings ---
EMBEDDING_PROVIDER=gemini     # gemini | openai | local
EMBEDDING_MODEL=models/embedding-001   # or text-embedding-3-small | BAAI/bge-large-en-v1.5

# --- Vector Store ---
VECTOR_STORE_PROVIDER=chromadb   # chromadb | faiss
CHROMA_PERSIST_DIR=./data/chromadb
FAISS_INDEX_PATH=./data/faiss_index

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
ENABLE_HYBRID_SEARCH=true
ENABLE_RERANKER=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501","http://localhost:8000"]

# --- Data ---
UPLOAD_DIR=./data/uploads
